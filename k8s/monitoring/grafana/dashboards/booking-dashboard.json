{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["booking-service", "eventticketing"],
  "title": "Booking Service Dashboard",
  "uid": "booking-service-dashboard",
  "version": 1,
  "time": { "from": "now-1h", "to": "now" },
  "timezone": "browser",
  "panels": [
    {
      "id": 1,
      "title": "Booking Errors",
      "description": "LogQL — ERROR-level log lines from booking-service",
      "type": "logs",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{app=\"eventticketing\", service=\"booking-service\"} |= \"ERROR\"",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Saga State Transitions",
      "description": "LogQL — Every booking status transition logged by BookingService",
      "type": "logs",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{app=\"eventticketing\", service=\"booking-service\"} |= \"transitioning\"",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Feign Call Outcomes",
      "description": "LogQL — Successful Feign calls vs failures from booking-service",
      "type": "logs",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{app=\"eventticketing\", service=\"booking-service\"} |~ \"returned successfully|Feign call to.*failed\"",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "HTTP Request Rate",
      "description": "PromQL — Requests per second per endpoint",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (uri) (rate(http_server_requests_seconds_count{job=\"booking-service\"}[5m]))",
          "refId": "A",
          "legendFormat": "{{uri}}"
        }
      ]
    },
    {
      "id": 5,
      "title": "Latency P50 / P95 / P99",
      "description": "PromQL — Latency percentiles per endpoint",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.99, sum by (le) (rate(http_server_requests_seconds_bucket{job=\"booking-service\"}[5m])))",
          "refId": "A",
          "legendFormat": "p99"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum by (le) (rate(http_server_requests_seconds_bucket{job=\"booking-service\"}[5m])))",
          "refId": "B",
          "legendFormat": "p95"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.50, sum by (le) (rate(http_server_requests_seconds_bucket{job=\"booking-service\"}[5m])))",
          "refId": "C",
          "legendFormat": "p50"
        }
      ]
    },
    {
      "id": 6,
      "title": "JVM Heap Usage",
      "description": "PromQL — Heap used vs committed",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "jvm_memory_used_bytes{job=\"booking-service\", area=\"heap\"}",
          "refId": "A",
          "legendFormat": "heap used"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "jvm_memory_committed_bytes{job=\"booking-service\", area=\"heap\"}",
          "refId": "B",
          "legendFormat": "heap committed"
        }
      ]
    },
    {
      "id": 7,
      "title": "Saga Queue Processing Rate",
      "description": "PromQL — Rate of messages consumed from the booking.saga-feedback queue",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 24, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(spring_rabbitmq_listener_seconds_count{queue=\"booking.saga-feedback\"}[5m])",
          "refId": "A",
          "legendFormat": "messages/sec"
        }
      ]
    }
  ]
}