{
  "__inputs": [],
  "__requires": [],
  "annotations": {
    "list": []
  },
  "description": "Sales Service Dashboard — LogQL Panels",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "id": 1,
      "title": "Sales Service — Error Rate (per minute)",
      "description": "Count of ERROR-level log lines from sales-service per minute. Spike detection: if sales-service logs many ERRORs in one minute something is wrong.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum(count_over_time({app=\"eventticketing\", service=\"sales-service\", level=\"ERROR\"} | json [1m]))",
          "legendFormat": "errors/min",
          "refId": "A"
        }
      ],
      "options": {
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          },
          "unit": "short"
        }
      }
    },
    {
      "id": 2,
      "title": "Sales Service — Feign Call Outcomes",
      "description": "Successful Feign responses vs FeignException catches. Detect when user-service or booking-service or event-service is degraded.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum(count_over_time({app=\"eventticketing\", service=\"sales-service\"} | json | message =~ \".*returned successfully.*\" [5m]))",
          "legendFormat": "Feign success",
          "refId": "A"
        },
        {
          "expr": "sum(count_over_time({app=\"eventticketing\", service=\"sales-service\"} | json | message =~ \".*Feign call to.*failed.*\" [5m]))",
          "legendFormat": "Feign failures",
          "refId": "B"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          },
          "unit": "short"
        }
      }
    },
    {
      "id": 3,
      "title": "Sales Service — RabbitMQ Payment Event Audit",
      "description": "Payment events published and consumed filtered by routing key. Shows how many payment.initiated, payment.completed, payment.failed, payment.refunded events were processed.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum(count_over_time({app=\"eventticketing\", service=\"sales-service\"} | json | message =~ \".*Published.*\" [5m]))",
          "legendFormat": "events published",
          "refId": "A"
        },
        {
          "expr": "sum(count_over_time({app=\"eventticketing\", service=\"sales-service\"} | json | message =~ \".*Consuming.*\" [5m]))",
          "legendFormat": "events consumed",
          "refId": "B"
        },
        {
          "expr": "sum(count_over_time({app=\"eventticketing\", service=\"sales-service\"} | json | routingKey =~ \"payment.*\" [5m]))",
          "legendFormat": "payment.* routing key",
          "refId": "C"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          },
          "unit": "short"
        }
      }
    },
    {
      "id": 4,
      "title": "Sales Service — HTTP Request Rate by URI",
      "description": "Requests per second per endpoint. Which sales-service endpoints are under the most load.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (uri) (rate(http_server_requests_seconds_count{service=\"sales-service\"}[5m]))",
          "legendFormat": "{{uri}}",
          "refId": "A"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "reqps"
        }
      }
    },
    {
      "id": 5,
      "title": "Sales Service — HTTP P99 Latency by URI",
      "description": "P99 request latency per endpoint. Detect slow endpoints (e.g. S5-F10 tier analytics Feign fan-out).",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum by (le, uri) (rate(http_server_requests_seconds_bucket{service=\"sales-service\"}[5m])))",
          "legendFormat": "{{uri}}",
          "refId": "A"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "s"
        }
      }
    },
    {
      "id": 6,
      "title": "Sales Service — JVM Heap Used",
      "description": "Heap memory in use. Memory pressure before OOM under saga load.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 32 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(jvm_memory_used_bytes{service=\"sales-service\", area=\"heap\"})",
          "legendFormat": "heap used",
          "refId": "A"
        }
      ],
      "options": {
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "bytes"
        }
      }
    },
    {
      "id": 7,
      "title": "Sales Service — HikariCP Active Connections",
      "description": "Active DB connections vs pool. Pool exhaustion alert during saga fan-out.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 32 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "hikaricp_connections_active{service=\"sales-service\"}",
          "legendFormat": "active connections",
          "refId": "A"
        }
      ],
      "options": {
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "short"
        }
      }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["eventticketing", "sales-service", "logql", "promql"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Sales Service Dashboard",
  "uid": "sales-service-dashboard",
  "version": 1
}