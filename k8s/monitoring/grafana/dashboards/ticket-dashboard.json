{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["ticket-service", "eventticketing"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Ticket Service Dashboard",
  "uid": "ticket-service-dashboard",
  "version": 1,
  "panels": [
    {
      "id": 1,
      "title": "HTTP Request Rate (req/s per endpoint)",
      "description": "Requests per second to ticket-service endpoints, grouped by method and URI. Highlights which S4-F* features (issue, batch issue, nearby, history, analytics) are under the most load.",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 1, "fillOpacity": 10 },
          "unit": "reqps"
        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by(method, uri) (rate(http_server_requests_seconds_count{job=\"ticket-service\"}[5m]))",
          "legendFormat": "{{method}} {{uri}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "HTTP Latency Percentiles (P50 / P95 / P99)",
      "description": "Request latency percentiles for ticket-service endpoints. S4-F3 (findNearbyTickets) does N+1 Feign calls and should show the highest tail — useful for catching downstream booking/event service degradation.",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 1, "fillOpacity": 10 },
          "unit": "s"
        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.50, sum by(le, uri) (rate(http_server_requests_seconds_bucket{job=\"ticket-service\"}[5m])))",
          "legendFormat": "P50 {{uri}}",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum by(le, uri) (rate(http_server_requests_seconds_bucket{job=\"ticket-service\"}[5m])))",
          "legendFormat": "P95 {{uri}}",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.99, sum by(le, uri) (rate(http_server_requests_seconds_bucket{job=\"ticket-service\"}[5m])))",
          "legendFormat": "P99 {{uri}}",
          "refId": "C"
        }
      ]
    },
    {
      "id": 3,
      "title": "Saga Listener Throughput (ticket.booking.saga-listener)",
      "description": "RabbitMQ listener invocations per second on the booking saga queue, split by success vs failure. A rising failure rate means messages are heading to ticket.booking.saga-listener.dlq.",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 1, "fillOpacity": 10 },
          "unit": "ops"
        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by(result) (rate(spring_rabbitmq_listener_seconds_count{job=\"ticket-service\", queue=\"ticket.booking.saga-listener\"}[5m]))",
          "legendFormat": "{{result}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Redis Cache Hit Ratio (per cache)",
      "description": "Hit ratio per cache name (S4-F1, S4-F3, S4-F5, S4-F6, S4-F8, S4-F9, S4-F10, ticket detail). A drop below ~70%% on hot caches indicates an eviction storm or misuse of @CacheEvict.",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 1, "fillOpacity": 10 },
          "unit": "percentunit",
          "min": 0,
          "max": 1
        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": ["mean", "min"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by(cache) (rate(cache_gets_total{job=\"ticket-service\", result=\"hit\"}[5m])) / clamp_min(sum by(cache) (rate(cache_gets_total{job=\"ticket-service\"}[5m])), 0.001)",
          "legendFormat": "{{cache}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "JVM Heap Usage",
      "description": "JVM heap memory used vs max for ticket-service. Watch for sustained growth approaching max — Cassandra driver buffers and Mongo cursors are common culprits.",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 1, "fillOpacity": 10 },
          "unit": "bytes"
        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "jvm_memory_used_bytes{job=\"ticket-service\", area=\"heap\"}",
          "legendFormat": "heap used",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "jvm_memory_max_bytes{job=\"ticket-service\", area=\"heap\"}",
          "legendFormat": "heap max",
          "refId": "B"
        }
      ]
    },
    {
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 24
      },
      "id": 6,
      "title": "Ticket-Service ERROR Rate",
      "description": "Tracks ERROR logs emitted by ticket-service. Useful for detecting spikes caused by failed ticket issuance, cache failures, or downstream service outages.",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(count_over_time({app=\"eventticketing\", service=\"ticket-service\", level=\"ERROR\"}[1m]))",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 24
      },
      "id": 7,
      "title": "Feign Call Failures",
      "description": "Counts failed Feign calls to booking-service and event-service. Helps identify downstream microservice instability affecting S4-F1, S4-F2, S4-F3, S4-F4, and S4-F9.",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(count_over_time({app=\"eventticketing\", service=\"ticket-service\"} |= \"Feign call to\" |= \"failed\" [5m]))",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 32
      },
      "id": 8,
      "title": "Successful Feign Calls",
      "description": "Tracks successful Feign invocations between ticket-service and external services. Useful for validating healthy communication with booking-service and event-service.",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(count_over_time({app=\"eventticketing\", service=\"ticket-service\"} |= \"returned successfully\" [5m]))",
          "refId": "A"
        }
      ]
    }

  ]
}
