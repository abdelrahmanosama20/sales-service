{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["user-service", "eventticketing"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "User Service Dashboard",
  "uid": "user-service-dashboard",
  "version": 1,
  "panels": [
    {
      "id": 1,
      "title": "Error Rate (errors per minute)",
      "description": "Count of ERROR-level log lines from user-service per minute. Spike detection — sudden increases indicate registration or authentication failures.",
      "type": "timeseries",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "red" },
          "custom": { "lineWidth": 1, "fillOpacity": 10 },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": [], "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum(count_over_time({app=\"eventticketing\", service=\"user-service\", level=\"ERROR\"}[1m]))",
          "legendFormat": "errors/min",
          "queryType": "range",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "RabbitMQ Event Audit (user.registered / user.deactivated)",
      "description": "Log lines emitted by user-service event publishers and consumers, filtered by routing key. Shows how many user.registered and user.deactivated events were published.",
      "type": "logs",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showCommonLabels": false,
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": false
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{app=\"eventticketing\", service=\"user-service\"} |~ \"routingKey|user\\.registered|user\\.deactivated\"",
          "queryType": "range",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Feign Call Outcomes",
      "description": "Log lines for successful Feign responses and FeignException catches from user-service. Detects when downstream services (e.g. booking-service) are degraded.",
      "type": "logs",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showCommonLabels": false,
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": false
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{app=\"eventticketing\", service=\"user-service\"} |~ \"Feign|FeignException\"",
          "queryType": "range",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "HTTP Request Rate (req/s per endpoint)",
      "description": "Requests per second to user-service endpoints, grouped by method and URI. Shows which endpoints are under the most load.",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 1, "fillOpacity": 10 },
          "unit": "reqps"
        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by(method, uri) (rate(http_server_requests_seconds_count{job=\"user-service\"}[5m]))",
          "legendFormat": "{{method}} {{uri}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "HTTP Latency Percentiles (P50 / P95 / P99)",
      "description": "Request latency percentiles for user-service endpoints. Identifies slow endpoints caused by Feign calls or DB operations.",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 1, "fillOpacity": 10 },
          "unit": "s"
        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.50, sum by(le, uri) (rate(http_server_requests_seconds_bucket{job=\"user-service\"}[5m])))",
          "legendFormat": "P50 {{uri}}",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum by(le, uri) (rate(http_server_requests_seconds_bucket{job=\"user-service\"}[5m])))",
          "legendFormat": "P95 {{uri}}",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.99, sum by(le, uri) (rate(http_server_requests_seconds_bucket{job=\"user-service\"}[5m])))",
          "legendFormat": "P99 {{uri}}",
          "refId": "C"
        }
      ]
    },
    {
      "id": 6,
      "title": "JVM Heap Usage",
      "description": "JVM heap memory used by user-service over time. Alerts on memory pressure before OOM — watch for sustained growth approaching max heap.",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 1, "fillOpacity": 10 },
          "unit": "bytes"
        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "jvm_memory_used_bytes{job=\"user-service\", area=\"heap\"}",
          "legendFormat": "heap used",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "jvm_memory_max_bytes{job=\"user-service\", area=\"heap\"}",
          "legendFormat": "heap max",
          "refId": "B"
        }
      ]
    }
  ]
}
