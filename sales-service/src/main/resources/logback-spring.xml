<configuration>
    <appender name="LOKI" class="com.github.loki4j.logback.Loki4jAppender">
        <http>
            <url>http://loki.monitoring.svc.cluster.local:3100/loki/api/v1/push</url>
        </http>
        <format>
            <label>
                <pattern>app=eventticketing,service=sales-service,level=%level,env=k8s</pattern>
            </label>
            <message>
                <pattern>{"timestamp":"%d{ISO8601}","level":"%level","service":"sales-service","thread":"%thread","logger":"%logger{36}","correlationId":"%X{correlationId:-}","saleId":"%X{saleId:-}","bookingId":"%X{bookingId:-}","userId":"%X{userId:-}","routingKey":"%X{routingKey:-}","message":"%msg"}</pattern>
            </message>
        </format>
    </appender>
    <root level="INFO">
        <appender-ref ref="LOKI"/>
    </root>
</configuration>